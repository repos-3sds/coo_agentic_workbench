# DCE Account Opening — Environment Variables
# =============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is git-ignored — never commit real secrets.

# ─────────────────────────────────────────────
# MariaDB — local Docker
# ─────────────────────────────────────────────
DB_ROOT_PASSWORD=root_dce_2026
DCE_DB_HOST=127.0.0.1
DCE_DB_PORT=3307
DCE_DB_USER=dce_user
DCE_DB_PASSWORD=dce_pass_2026
DCE_DB_NAME=dce_agent

# ─────────────────────────────────────────────
# MCP Server Ports
# ─────────────────────────────────────────────
PORT=8000
PORT_SA3=8001
MCP_TRANSPORT=streamable-http

# ─────────────────────────────────────────────
# Anthropic — used by Dify LLM nodes
# Get your key at: https://console.anthropic.com
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─────────────────────────────────────────────
# Dify — set after Dify is running
# ─────────────────────────────────────────────
# DIFY_BASE_URL=http://localhost:80
# DIFY_API_KEY=your_dify_api_key_here
